{
    "compilerOptions": {
        "target": "es6", // 컴파일된 JavaScript 코드의 ECMAScript 버전
        "module": "esnext", // 모듈 시스템 (ES6 모듈 사용)
        "lib": ["dom", "dom.iterable", "esnext", "es6"], // 사용할 라이브러리 설정
        "jsx": "react-jsx", // JSX 처리를 위한 설정 (React 17 이상에서는 "react-jsx"를 사용)
        "esModuleInterop": true, // CommonJS 모듈을 ES 모듈처럼 가져오기 위해 필요
        "allowSyntheticDefaultImports": true, // import React from 'react'; 같은 구문을 허용
        "strict": true, // 모든 엄격한 타입 검사 옵션 활성화
        "forceConsistentCasingInFileNames": true, // 파일 이름 대소문자 일관성 강제
        "moduleResolution": "bundler", // 모듈 해석 전략 (Node.js 스타일)
        "resolveJsonModule": true, // JSON 모듈을 가져올 수 있도록 설정
        "isolatedModules": true, // 각 파일을 개별 모듈로 처리
        "skipLibCheck": true, // 라이브러리 타입 검사를 건너뜀 (컴파일 속도 향상)
        "noEmit": true,
        "allowJs": true, // .js 파일을 TypeScript 프로젝트에서 사용할 수 있도록 허용
        "types": ["node"]
    },
    "include": ["src", "src/types"],
    "exclude": ["node_modules"] // 컴파일에서 제외할 파일 경로
}
